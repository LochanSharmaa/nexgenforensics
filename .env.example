# SIFS Creative Reasoning Engine - Example Environment Configuration

# Database & Cache
DATABASE_URL=sqlite:///./sifs_ie_ai.db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=supersecretjwtsecretchangeitinprod
CORS_ORIGINS_STR=http://localhost:3000

# LLM Providers Configuration (gemini | mock)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# Image Providers Configuration (gemini_image | mock)
IMAGE_PROVIDER=gemini_image
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# Embedding Provider Configuration (gemini | mock)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/text-embedding-004

# Storage (S3 / Cloudinary)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BUSINESS=

# Clerk Configuration
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
