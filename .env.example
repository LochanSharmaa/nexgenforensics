# SIFS Imagination Expander AI - Environment Configuration

# Database & Cache
DATABASE_URL=sqlite:///./sifs_ie_ai.db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=supersecretjwtsecretchangeitinprod
CORS_ORIGINS=http://localhost:3000

# LLM Providers Configuration
# Supported: mock | gemini | openai | local_vllm
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=gpt-4o-mini

# Image Providers Configuration
# Supported: mock | gemini_image | comfyui | diffusers
IMAGE_PROVIDER=mock
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
COMFYUI_URL=http://localhost:8188

# Storage (Optional for production)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Embedding Provider Configuration (For diversity checking)
# Supported: mock | sentence_transformers | gemini_embedding
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
